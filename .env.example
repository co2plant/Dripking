# Spring profile
SPRING_PROFILES_ACTIVE=prod

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=dripking
POSTGRES_USER=dripking
POSTGRES_PASSWORD=change-me

# JWT
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-bytes
JWT_EXPIRATION=86400000

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://example.com

# Optional local-dev smoke admin. Only used with the dev profile when enabled.
DEV_ADMIN_ENABLED=false
DEV_ADMIN_EMAIL=admin@example.com
DEV_ADMIN_PASSWORD=change-me-16-chars
DEV_ADMIN_NICKNAME=local-admin

# S3-compatible image storage
S3_ENDPOINT=https://s3.example.com
S3_REGION=ap-northeast-2
S3_BUCKET=dripking-content-images
S3_ACCESS_KEY=change-me
S3_SECRET_KEY=change-me
S3_PUBLIC_BASE_URL=https://cdn.example.com/dripking-content-images
S3_KEY_PREFIX=content-images

# Logging
LOG_PATH=/var/log/dripking
