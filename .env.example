# Spring profile. Use perf to load synthetic performance seed data.
SPRING_PROFILES_ACTIVE=dev

# PostgreSQL. In Docker Compose, use the service name.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=dripking
POSTGRES_USER=dripking
POSTGRES_PASSWORD=dripking

# Host port for the backend container
BACKEND_PORT=8080

# JWT
JWT_SECRET=dev-only-change-me-dev-only-change-me-dev-only-change-me
JWT_EXPIRATION=86400000

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional local-dev smoke admin. Only used with the dev profile when enabled.
DEV_ADMIN_ENABLED=false
DEV_ADMIN_EMAIL=admin@example.com
DEV_ADMIN_PASSWORD=change-me-16-chars
DEV_ADMIN_NICKNAME=local-admin

# Course generation gate/cost controls
COURSE_GUEST_TRIAL_LIMIT=2
COURSE_CAPTCHA_ENABLED=true
COURSE_CAPTCHA_SECRET=
COURSE_CAPTCHA_VERIFY_URL=https://www.google.com/recaptcha/api/siteverify
COURSE_CAPTCHA_DEV_TOKEN=dev-captcha
COURSE_RATE_LIMIT_ENABLED=true
COURSE_RATE_LIMIT_WINDOW_SECONDS=60
COURSE_RATE_LIMIT_AUTHENTICATED_LIMIT=20
COURSE_RATE_LIMIT_GUEST_LIMIT=5
COURSE_RATE_LIMIT_IP_LIMIT=30
COURSE_RATE_LIMIT_GLOBAL_LIMIT=100
COURSE_HARD_CAP_ENABLED=true
COURSE_ESTIMATED_COST_PER_GENERATION=0
COURSE_MONTHLY_HARD_CAP=5000

# S3-compatible image storage
S3_ENDPOINT=https://s3.example.com
S3_REGION=ap-northeast-2
S3_BUCKET=dripking-content-images
S3_ACCESS_KEY=change-me
S3_SECRET_KEY=change-me
S3_PUBLIC_BASE_URL=https://cdn.example.com/dripking-content-images
S3_KEY_PREFIX=content-images

# Logging
LOG_PATH=/var/log/dripking
